{
  "name": "joystickz-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Joystickz design system monorepo — tokens, web components, and docs site.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/docs",
    "build": "npm run build --workspace apps/docs",
    "start": "npm run start --workspace apps/docs",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
